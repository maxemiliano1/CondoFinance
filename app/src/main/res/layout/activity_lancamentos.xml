<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="25dp"
        android:gravity="center"
        android:text="Gestão de Lançamentos"
        android:textColor="#1A237E"
        android:textSize="26sp"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/groupTipo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:background="@android:color/white"
        android:elevation="2dp"
        android:gravity="center"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/radioSaida"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#D32F2F"
            android:checked="true"
            android:text="Despesa"
            android:textColor="#D32F2F"
            android:textStyle="bold" />

        <RadioButton
            android:id="@+id/radioEntrada"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="30dp"
            android:buttonTint="#2E7D32"
            android:text="Receita"
            android:textColor="#2E7D32"
            android:textStyle="bold" />
    </RadioGroup>

    <EditText
        android:id="@+id/editData"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginBottom="12dp"
        android:background="#FFFFFF"
        android:drawableStart="@android:drawable/ic_menu_my_calendar"
        android:drawablePadding="10dp"
        android:elevation="1dp"
        android:hint="Data da Operação"
        android:padding="10dp"
        android:textColor="#000000" />

    <AutoCompleteTextView
        android:id="@+id/editDescricao"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginBottom="12dp"
        android:background="#FFFFFF"
        android:completionThreshold="1"
        android:elevation="1dp"
        android:hint="Descrição (ex: Jardineiro)"
        android:padding="12dp"
        android:textColor="#000000"
        android:textColorHint="#546E7A" />

    <EditText
        android:id="@+id/editValor"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginBottom="25dp"
        android:background="#FFFFFF"
        android:elevation="1dp"
        android:hint="Valor (0,00)"
        android:inputType="numberDecimal"
        android:digits="0123456789,."
        android:padding="12dp"
        android:textColor="#000000"
        android:textColorHint="#546E7A" />

    <Button
        android:id="@+id/btnSalvarLancamento"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="15dp"
        android:backgroundTint="#1A237E"
        android:elevation="4dp"
        android:text="Confirmar Lançamento"
        android:textAllCaps="true"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Histórico Recente"
        android:textAllCaps="true"
        android:textColor="#546E7A"
        android:textSize="12sp"
        android:textStyle="bold" />

    <ListView
        android:id="@+id/listaLancamentosRecentes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp" />

</LinearLayout>